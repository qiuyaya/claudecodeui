# Claude Code UI Environment Configuration
# Only includes variables that are actually used in the code
#
# TIP: Run 'cloudcli status' to see where this file should be located
#      and to view your current configuration.
#
# Available CLI commands:
#   claude-code-ui    - Start the server (default)
#   cloudcli start    - Start the server
#   cloudcli status   - Show configuration and data locations
#   cloudcli help     - Show help information
#   cloudcli version  - Show version information

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Backend server port (Express API + WebSocket server)
#API server
PORT=3001
#Frontend port
VITE_PORT=5173

# Node environment (development | production)
NODE_ENV=development

# Skip rate limiting in development (set to true for testing)
# NEVER set this to true in production!
# SKIP_RATE_LIMIT=false

# Request size limits
# MAX_BODY_SIZE=10mb
# MAX_FILE_SIZE=50mb
# MAX_CONNECTIONS=100

# HTTPS Configuration
# Force HTTPS redirect in production (requires TRUST_PROXY to be set)
# FORCE_HTTPS=true

# Trust proxy setting for deployments behind a reverse proxy (e.g. Nginx, Cloudflare)
# Needed for correct client IP detection, rate limiting, and HTTPS redirect
# Examples: true, 1, loopback, 10.0.0.0/8
# TRUST_PROXY=1

# Hostname for HTTPS redirect (prevents Host header injection)
# APP_HOST=yourdomain.com

# =============================================================================
# PLATFORM MODE CONFIGURATION (For Managed/Hosted Deployments)
# =============================================================================

# Enable Platform mode (authentication handled by external proxy)
# VITE_IS_PLATFORM=false

# Trusted proxy IP addresses (comma-separated)
# Only these IPs can make authenticated requests in Platform mode
# Example: TRUSTED_PROXIES=127.0.0.1,::1,10.0.0.1
# TRUSTED_PROXIES=

# Required proxy headers in Platform mode:
# - x-proxy-user-id: User ID from authentication proxy
# - x-proxy-username: Username from authentication proxy
# - x-proxy-email: (Optional) User email from authentication proxy

# Uncomment the following line if you have a custom claude cli path other than the default "claude"
# CLAUDE_CLI_PATH=claude

# =============================================================================
# SECURITY CONFIGURATION [REQUIRED FOR PRODUCTION]
# =============================================================================

# JWT Secret Key [REQUIRED FOR PRODUCTION]
# Generate a secure 32+ character secret using:
#   openssl rand -base64 32
# OR
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# In development, a default secret is used automatically.
# In production, the server will refuse to start if JWT_SECRET is not set or too short.
# JWT_SECRET=

# Refresh token secret (recommended to set separately from JWT_SECRET)
# If not set, falls back to JWT_SECRET. Generate with: openssl rand -base64 32
# REFRESH_TOKEN_SECRET=

# Encryption key for stored credentials (API keys, tokens in DB)
# If not set, falls back to JWT_SECRET. Generate with: openssl rand -base64 32
# ENCRYPTION_KEY=

# Access token expiry time (default: 1h)
# Examples: 60s, 5m, 2h, 1d, 7d
# TOKEN_EXPIRY=1h

# CORS Allowed Origins [REQUIRED FOR PRODUCTION]
# Comma-separated list of domains allowed to access the API
#
# Development (default if not set):
#   http://localhost:5173,http://localhost:3001
#
# Production examples:
#   ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
#   ALLOWED_ORIGINS=https://app.yourdomain.com
#
# ⚠️  NOT RECOMMENDED: Allow all origins (use only for testing)
#   ALLOWED_ORIGINS=*
#
ALLOWED_ORIGINS=

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Path to the authentication database file
# This is where user credentials, API keys, and tokens are stored.
#
# To use a custom location:
# DATABASE_PATH=/path/to/your/custom/auth.db
#
# Claude Code context window size (maximum tokens per session)
VITE_CONTEXT_WINDOW=160000
CONTEXT_WINDOW=160000

# =============================================================================
# AGENT API CONFIGURATION
# =============================================================================

# Allow agent API to bypass permission checks (server-side only, default: false)
# AGENT_BYPASS_PERMISSIONS=false
